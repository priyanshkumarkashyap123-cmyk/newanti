{
    "name": "backend-rust",
    "version": "0.1.0",
    "type": "module",
    "main": "./pkg/backend_rust.js",
    "types": "./pkg/backend_rust.d.ts",
    "exports": {
        ".": {
            "import": "./pkg/backend_rust.js",
            "types": "./pkg/backend_rust.d.ts"
        },
        "./pkg/*": "./pkg/*"
    },
    "files": [
        "pkg"
    ],
    "scripts": {
        "build": "wasm-pack build --target web --out-dir ./pkg --release || echo 'wasm-pack not found, skipping backend-rust build (pre-built pkg committed)'"
    }
}
