{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "BeamLab Ultimate",
    "version": "1.0.0",
    "identifier": "tech.beamlabultimate.app",
    "build": {
        "beforeDevCommand": "cd ../web && pnpm dev",
        "devUrl": "http://localhost:5173",
        "beforeBuildCommand": "cd ../web && pnpm build",
        "frontendDist": "../web/dist"
    },
    "app": {
        "windows": [
            {
                "title": "BeamLab Ultimate - AI Architect",
                "width": 1400,
                "height": 900,
                "resizable": true,
                "fullscreen": false,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "app",
            "dmg",
            "nsis"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "minimumSystemVersion": "10.13"
        },
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": ""
        }
    }
}