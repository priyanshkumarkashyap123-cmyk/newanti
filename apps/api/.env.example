# ============================================
# BeamLab API Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# OpenAI / AI Configuration
# ============================================
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://localhost:27017/beamlab
MONGODB_USERNAME=admin
MONGODB_PASSWORD=your_password_here

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# ============================================
# EMAIL CONFIGURATION (Required for signup/password reset)
# ============================================
# Choose one: nodemailer or sendgrid
EMAIL_SERVICE=nodemailer

# --- Option 1: Nodemailer with SMTP ---
# GMAIL SETUP:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-character password below
# 
# OUTLOOK SETUP:
#   1. Use your Outlook email and password
#   2. Or generate an App Password
#
# CUSTOM SMTP:
#   1. Use your email provider's SMTP settings
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-16-chars

# --- Option 2: SendGrid (Comment out SMTP if using this) ---
# SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Email Sender Information
FROM_EMAIL=noreply@beamlabultimate.tech
FROM_NAME=BeamLab

# Frontend URL for email links (used in verification/reset links)
FRONTEND_URL=http://localhost:5173

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# CORS CONFIGURATION
# ============================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,https://beamlabultimate.tech

# ============================================
# OAUTH CONFIGURATION
# ============================================

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/callback/google

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:5173/auth/callback/github

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_CALLBACK_URL=http://localhost:5173/auth/callback/linkedin

# ============================================
# PAYMENT GATEWAY (Razorpay)
# ============================================
# Get these from: https://dashboard.razorpay.com/app/keys (Test Mode)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Webhook secret - set when creating webhook in Razorpay Dashboard
# Dashboard → Settings → Webhooks → Add New Webhook
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ============================================
# FEA SOLVER CONFIGURATION
# ============================================
PYTHON_SOLVER_URL=http://localhost:5000
