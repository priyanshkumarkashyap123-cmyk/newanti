# ============================================
# BeamLab API — Environment Variables
# Copy to .env for local development (never commit secrets)
# Variables validated by Zod schema in src/config/env.ts
# ============================================

# ============================================
# SERVER
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://localhost:27017/beamlab

# ============================================
# AUTHENTICATION — Clerk (primary)
# ============================================
# Get keys from: https://dashboard.clerk.com
USE_CLERK=true
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# ============================================
# AUTHENTICATION — JWT (fallback / legacy)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# ============================================
# CORS
# ============================================
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ============================================
# AI
# ============================================
GEMINI_API_KEY=your-gemini-api-key

# ============================================
# PAYMENT GATEWAY — PhonePe
# ============================================

# TEMPORARY BILLING BYPASS
# true  = unlock all users to enterprise/pro features (default while KYC is pending)
# false = enforce payment/subscription verification
TEMP_UNLOCK_ALL=true

# Get from: https://developer.phonepe.com (Sandbox / Production)
PHONEPE_MERCHANT_ID=your_phonepe_merchant_id
PHONEPE_SALT_KEY=your_phonepe_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT

# ============================================
# OBSERVABILITY
# ============================================
# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================
# INTER-SERVICE URLs
# ============================================
PYTHON_API_URL=http://localhost:8000
RUST_API_URL=http://localhost:8080
