# ============================================
# BeamLab API — Production Environment Template
# Copy to .env.production (never commit real secrets)
# Fill from Azure App Service Settings / Key Vault
# ============================================

# --------------------------------------------
# GENERAL
# --------------------------------------------
ENVIRONMENT=production
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# --------------------------------------------
# DATABASE
# --------------------------------------------
# MongoDB Atlas SRV (no quotes)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/beamlab?retryWrites=true&w=majority

# --------------------------------------------
# AUTH — Clerk
USE_CLERK=true
CLERK_SECRET_KEY=<set-in-azure-app-settings>
CLERK_PUBLISHABLE_KEY=<set-in-azure-app-settings>

# --------------------------------------------
# AUTH — JWT fallback (keep strong, 32+ chars)
JWT_SECRET=<set-in-azure-app-settings>
JWT_REFRESH_SECRET=<set-in-azure-app-settings>

# --------------------------------------------
# CORS / FRONTEND
FRONTEND_URL=https://beamlabultimate.tech
CORS_ALLOWED_ORIGINS=https://beamlabultimate.tech,https://www.beamlabultimate.tech,https://brave-mushroom-0eae8ec00.4.azurestaticapps.net

# --------------------------------------------
# SERVICE TRUST (Node -> Python/Rust)
INTERNAL_SERVICE_SECRET=<set-in-azure-app-settings>

# --------------------------------------------
# INTER-SERVICE URLs
PYTHON_API_URL=https://beamlab-backend-python.azurewebsites.net
RUST_API_URL=https://beamlab-rust-api.azurewebsites.net

# --------------------------------------------
# PAYMENTS — Razorpay (production keys)
RAZORPAY_KEY_ID=<set-in-azure-app-settings>
RAZORPAY_KEY_SECRET=<set-in-azure-app-settings>
RAZORPAY_WEBHOOK_SECRET=<set-in-azure-app-settings>

# --------------------------------------------
# PAYMENTS — PhonePe (if enabled)
PHONEPE_MERCHANT_ID=<set-in-azure-app-settings>
PHONEPE_SALT_KEY=<set-in-azure-app-settings>
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=PROD
TEMP_UNLOCK_ALL=false

# --------------------------------------------
# AI
GEMINI_API_KEY=<set-in-azure-app-settings>

# --------------------------------------------
# OBSERVABILITY
# Do not quote DSN; keep raw URL
SENTRY_DSN=<set-in-azure-app-settings>

# --------------------------------------------
# REDIS (optional cache)
REDIS_URL=<set-if-enabled>

# Notes:
# - Do NOT wrap values in quotes (avoids parsing failures noted on 2026-03-20).
# - Store actual secrets in Azure App Service settings or Key Vault, not in files.
# - Health probes should hit /healthz; readiness /readyz (DB-gated).
