{
  "name": "@beamlab/api",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx src/index.ts",
    "dev:watch": "tsx watch --env-file=.env src/index.ts",
    "build": "node build.mjs",
    "build:tsc": "tsc --skipLibCheck --noEmit false",
    "start": "node dist/index.cjs",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 120",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:contracts": "vitest run tests/proxy-contracts.test.ts tests/design-core-routes.test.ts tests/design-geotech-routes.test.ts",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx src/migrations/runner.ts",
    "migrate:status": "tsx src/migrations/runner.ts --status",
    "migrate:rollback": "tsx src/migrations/runner.ts --down",
    "migrate:preflight": "tsx scripts/migration-preflight.ts"
  },
  "dependencies": {
    "@clerk/express": "^2.0.8",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.37.0",
    "@sentry/profiling-node": "^10.37.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "express": "^5.1.0",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.10.0",
    "mongoose": "^9.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.11",
    "openai": "^6.15.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "query-string": "^9.3.1",
    "razorpay": "^2.9.6",
    "redis": "^5.11.0",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.9.3",
    "@types/nodemailer": "^7.0.4",
    "@types/query-string": "^6.3.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.15.0",
    "fast-check": "^3.23.2",
    "node-fetch": "^3.3.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.1"
  }
}
