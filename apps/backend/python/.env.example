# Backend Python environment template
# Copy to .env for local development only (never commit secrets)

# App runtime
PORT=8000
ENVIRONMENT=development
PYTHON_ENV=development
LOG_LEVEL=INFO

# AI provider
GEMINI_API_KEY=mock-key-local-dev
USE_MOCK_AI=true

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,http://127.0.0.1:5173

# Production example (set in Azure App Service)
# FRONTEND_URL=https://beamlabultimate.tech
# ALLOWED_ORIGINS=https://beamlabultimate.tech,https://www.beamlabultimate.tech

# Downstream service URLs
NODE_API_URL=http://localhost:3001
RUST_API_URL=http://localhost:8080

# Production example (set in Azure App Service)
# NODE_API_URL=https://beamlab-backend-node-prod.azurewebsites.net
# RUST_API_URL=https://beamlab-rust-api-prod.azurewebsites.net

# Rust backend tuning
ENABLE_RUST_BACKEND=true
RUST_API_TIMEOUT=120
RUST_NODE_THRESHOLD=500

# Worker pool
ANALYSIS_WORKERS=4
# Database
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>

# Security
SESSION_SECRET=mock-session-secret
INTERNAL_SERVICE_SECRET=mock-internal-secret
