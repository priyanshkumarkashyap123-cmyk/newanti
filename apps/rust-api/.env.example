# BeamLab Rust API Environment Variables

# Server Configuration
RUST_API_PORT=3002
RUST_LOG=beamlab_api=debug,tower_http=debug

# Database
MONGODB_URI=mongodb://localhost:27017/beamlab

# Authentication (use same secret as Node.js API)
JWT_SECRET=your-jwt-secret-here

# Optional: API Key for service-to-service auth
# RUST_API_KEY=your-api-key-here

# Performance Tuning (optional)
# RAYON_NUM_THREADS=8  # Number of worker threads for parallel analysis
