<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="python" arguments="-m gunicorn -w 2 -k uvicorn.workers.UvicornWorker main:app --bind 0.0.0.0:%HTTP_PLATFORM_PORT% --timeout 120 --preload" startupTimeLimit="120" />
  </system.webServer>
</configuration>
