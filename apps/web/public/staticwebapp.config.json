{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/assets/*",
            "*.{css,js,json,png,jpg,jpeg,gif,ico,svg,woff,woff2,ttf,eot}"
        ]
    },
    "routes": [
        {
            "route": "/sign-in/*",
            "rewrite": "/index.html"
        },
        {
            "route": "/sign-up/*",
            "rewrite": "/index.html"
        },
        {
            "route": "/dashboard",
            "rewrite": "/index.html"
        },
        {
            "route": "/app",
            "rewrite": "/index.html"
        },
        {
            "route": "/demo",
            "rewrite": "/index.html"
        },
        {
            "route": "/settings",
            "rewrite": "/index.html"
        },
        {
            "route": "/capabilities",
            "rewrite": "/index.html"
        },
        {
            "route": "/workspace/*",
            "rewrite": "/index.html"
        }
    ],
    "responseOverrides": {
        "404": {
            "rewrite": "/index.html",
            "statusCode": 200
        }
    },
    "globalHeaders": {
        "Cache-Control": "public, max-age=3600",
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "geolocation=(), microphone=(), camera=()"
    }
}