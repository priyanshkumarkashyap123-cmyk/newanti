  "screenshots": [
    {
      "src": "/screenshots/desktop-1.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Structural Analysis Dashboard"
    },
    {
      "src": "/screenshots/mobile-1.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile Project View"
    }
  ],
  "shortcuts": [
    {
      "name": "New Project",
      "short_name": "New",
      "description": "Create a new structural project",
      "url": "/projects/new",
      "icons": [{ "src": "/icons/shortcut-new.png", "sizes": "96x96" }]
    },
    {
      "name": "Recent Projects",
      "short_name": "Recent",
      "description": "View recent projects",
      "url": "/projects?filter=recent",
      "icons": [{ "src": "/icons/shortcut-recent.png", "sizes": "96x96" }]
    },
    {
      "name": "Run Analysis",
      "short_name": "Analyze",
      "description": "Run structural analysis",
      "url": "/analysis",
      "icons": [{ "src": "/icons/shortcut-analyze.png", "sizes": "96x96" }]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": [".json", ".ifc", ".dxf", "application/json"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/open",
      "accept": {
        "application/json": [".json", ".struct"],
        "application/x-ifc": [".ifc"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+structeng",
      "url": "/protocol?url=%s"
    }
  ]
}
