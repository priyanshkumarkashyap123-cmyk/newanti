# ============================================
# BeamLab Ultimate - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# ============================================
# AUTHENTICATION (Clerk)
# ============================================
# Get these from: https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ============================================
# API ENDPOINTS
# ============================================
# Backend API URL (Node.js/Express)
VITE_API_URL=http://localhost:3001

# Python API URL (FastAPI - for advanced computations)
VITE_PYTHON_API_URL=http://localhost:8081

# Rust API URL (high-performance advanced analysis)
VITE_RUST_API_URL=http://localhost:3002

# Optional WebSocket URL override for collaboration/progress streams
# If omitted, frontend derives it from Python API URL
VITE_WS_URL=ws://localhost:8081/ws

# ============================================
# MONITORING & ANALYTICS
# ============================================
# Sentry DSN for error tracking (optional)
# Get from: https://sentry.io
VITE_SENTRY_DSN=

# ============================================
# FEATURE FLAGS
# ============================================
# Enable experimental features
VITE_ENABLE_WEBGPU=true
VITE_ENABLE_COLLABORATION=false
VITE_ENABLE_AI_FEATURES=true

# ============================================
# PAYMENT GATEWAY (Razorpay)
# ============================================
VITE_RAZORPAY_KEY_ID=

# ============================================
# BUILD CONFIGURATION
# ============================================
# Set to 'production' for production builds
NODE_ENV=development

# Enable source maps (development only)
VITE_SOURCE_MAPS=true

# ============================================
# PERFORMANCE TUNING
# ============================================
# Maximum number of concurrent WASM workers
VITE_MAX_WORKERS=4

# Enable verbose logging
VITE_DEBUG=false
