# ============================================
# BeamLab Web — Environment Variables
# Copy to .env.local for local development (never commit secrets)
# ============================================

# ============================================
# AUTHENTICATION (Clerk)
# ============================================
# Get from: https://dashboard.clerk.com
VITE_USE_CLERK=true
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ============================================
# API ENDPOINTS
# ============================================
VITE_API_URL=http://localhost:3001
VITE_PYTHON_API_URL=http://localhost:8000
VITE_RUST_API_URL=http://localhost:8080

# WebSocket URL (if omitted, derived from Python API URL)
VITE_WEBSOCKET_URL=ws://localhost:8000/ws

# ============================================
# PAYMENTS — PhonePe
# ============================================
# TEMPORARY BILLING BYPASS
# true  = unlock all users to pro/enterprise features (default while KYC is pending)
# false = enforce payment/upgrade flow
VITE_TEMP_UNLOCK_ALL=true

# VITE_PHONEPE_MERCHANT_ID=your_merchant_id
# VITE_PHONEPE_ENV=UAT

# ============================================
# MONITORING & ANALYTICS
# ============================================
# Sentry DSN (optional)
# VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id
VITE_ENABLE_PERFORMANCE_METRICS=false

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_WEBGPU=true
VITE_ENABLE_COLLABORATION=false
VITE_ENABLE_AI_FEATURES=true

# ============================================
# AI CONFIGURATION (Google Gemini)
# ============================================
# API key for Google Gemini AI features
# Get from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
# Model to use (default: gemini-2.0-flash)
VITE_GEMINI_MODEL=gemini-2.0-flash
# Timeout for AI requests in milliseconds (default: 30000)
VITE_GEMINI_TIMEOUT=30000
# Prefer Gemini over other AI providers
VITE_PREFER_GEMINI=true

# ============================================
# API CONFIGURATION
# ============================================
# General API timeout in milliseconds (default: 30000)
VITE_API_TIMEOUT=30000

# ============================================
# PAYMENT GATEWAY (Razorpay)
# ============================================
VITE_RAZORPAY_KEY_ID=

# ============================================
# BUILD CONFIGURATION
# ============================================
# Set to 'production' for production builds
NODE_ENV=development

# Enable source maps (development only)
VITE_SOURCE_MAPS=true

# ============================================
# PERFORMANCE TUNING
# ============================================
# Maximum number of concurrent WASM workers
VITE_MAX_WORKERS=4

# Enable verbose logging
VITE_DEBUG=false
