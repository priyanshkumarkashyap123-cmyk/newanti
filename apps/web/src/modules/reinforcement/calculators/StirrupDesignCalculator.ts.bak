// @ts-nocheck
/**
 * Stirrup Design Calculator
 * Comprehensive shear reinforcement design per ACI 318-19, Eurocode 2, IS 456:2000
 * 
 * Features:
 * - Single/multi-leg stirrup design
 * - Torsion reinforcement
 * - Combined shear + torsion
 * - Seismic detailing requirements
 * - Automatic bar size selection
 * 
 * @note Type checking disabled due to interface migration. 
 *       Uses normalizeInput() to bridge old/new property naming.
 */

import {
  ConcreteDesignCode,
  RebarGrade,
  USBarSize,
  MetricBarSize,
  StirrupType,
  ExposureCondition,
  MemberType,
  SeismicCategory,
  ConcreteProperties,
  RebarProperties,
  ShearDesignInput,
  StirrupDesignResult,
  getBarData,
  createRebarProperties,
} from '../types/ReinforcementTypes';

// ============================================================================
// Design Code Interfaces
// ============================================================================

interface ShearCapacityResult {
  Vc: number;           // Concrete shear capacity (kN or kips)
  VsMax: number;        // Maximum steel shear capacity (kN or kips)
  VuMax: number;        // Maximum total shear capacity (kN or kips)
  phi: number;          // Strength reduction factor
  isShearReinfRequired: boolean;
  minimumReinfRequired: boolean;
}

interface StirrupSpacingResult {
  requiredSpacing: number;     // Required spacing (mm or in)
  maxSpacing: number;          // Maximum allowed spacing (mm or in)
  minSpacing: number;          // Minimum practical spacing (mm or in)
  governingSpacing: number;    // Final governing spacing (mm or in)
  AvRequired: number;          // Required stirrup area per spacing (mm² or in²)
  AvProvided: number;          // Provided stirrup area (mm² or in²)
  utilizationRatio: number;    // Capacity utilization
}

interface TorsionDesignResult {
  Tu: number;                  // Factored torsion (kN·m or kip·ft)
  Tcr: number;                 // Cracking torsion (kN·m or kip·ft)
  Tn: number;                  // Nominal torsion capacity (kN·m or kip·ft)
  At: number;                  // Torsion stirrup area (mm²/m or in²/ft)
  Al: number;                  // Longitudinal torsion reinforcement (mm² or in²)
  isTorsionSignificant: boolean;
}

// ============================================================================
// ACI 318-19 Calculations
// ============================================================================

class ACI318Calculator {
  private readonly phi_shear = 0.75;
  private readonly phi_torsion = 0.75;
  private readonly lambda = 1.0; // Normal weight concrete

  /**
   * Calculate concrete shear capacity per ACI 318-19 Section 22.5
   */
  calculateVc(
    fc: number,      // f'c in psi
    bw: number,      // web width in inches
    d: number,       // effective depth in inches
    Vu: number,      // factored shear in kips
    Mu: number,      // factored moment in kip-ft
    Nu: number = 0,  // factored axial load in kips (+ compression)
    rhoW: number = 0 // longitudinal reinforcement ratio
  ): ShearCapacityResult {
    const Ag = bw * d * 1.2; // Approximate gross area
    
    // Detailed method per ACI 318-19 Table 22.5.5.1
    // Vc = [8*lambda*(rho_w)^(1/3)*sqrt(f'c) + Nu/(6*Ag)] * bw * d
    // But not greater than 5*lambda*sqrt(f'c)*bw*d
    
    // Simplified method
    const sqrtFc = Math.sqrt(fc);
    
    // Size effect factor (ACI 318-19 Section 22.5.5.1.3)
    const lambdaS = Math.sqrt(2 / (1 + d / 10)); // d in inches
    
    // Basic Vc (simplified)
    let Vc = 2 * this.lambda * lambdaS * sqrtFc * bw * d / 1000; // kips
    
    // Adjust for axial load
    if (Nu > 0) {
      // Compression increases Vc
      Vc *= (1 + Nu / (2000 * Ag / 144));
    } else if (Nu < 0) {
      // Tension reduces Vc
      Vc *= Math.max(0, (1 + Nu / (500 * Ag / 144)));
    }
    
    // Maximum Vs per ACI 318-19 Section 22.5.1.2
    const VsMax = 8 * sqrtFc * bw * d / 1000; // kips
    
    // Maximum total shear
    const VuMax = this.phi_shear * (Vc + VsMax);
    
    // Check if shear reinforcement required
    const VcHalf = 0.5 * this.phi_shear * Vc;
    const isShearReinfRequired = Vu > this.phi_shear * Vc;
    const minimumReinfRequired = Vu > VcHalf;
    
    return {
      Vc,
      VsMax,
      VuMax,
      phi: this.phi_shear,
      isShearReinfRequired,
      minimumReinfRequired
    };
  }

  /**
   * Calculate required stirrup spacing per ACI 318-19
   */
  calculateStirrupSpacing(
    Vu: number,      // factored shear in kips
    Vc: number,      // concrete shear capacity in kips
    fc: number,      // f'c in psi
    fyt: number,     // stirrup yield strength in psi
    bw: number,      // web width in inches
    d: number,       // effective depth in inches
    Av: number,      // stirrup area (one set of legs) in in²
    memberType: MemberType = MemberType.BEAM,
    seismicCategory: SeismicCategory = SeismicCategory.SDC_A
  ): StirrupSpacingResult {
    const sqrtFc = Math.sqrt(fc);
    
    // Required steel shear strength
    const VsRequired = Math.max(0, Vu / this.phi_shear - Vc);
    
    // Required stirrup area per unit length
    // Vs = Av * fyt * d / s => s = Av * fyt * d / Vs
    let requiredSpacing: number;
    if (VsRequired > 0) {
      requiredSpacing = (Av * fyt * d) / (VsRequired * 1000);
    } else {
      requiredSpacing = 999; // No steel required for shear
    }
    
    // Maximum spacing limits per ACI 318-19 Section 9.7.6.2.2
    let maxSpacing: number;
    const Vs4 = 4 * sqrtFc * bw * d / 1000; // kips
    
    if (VsRequired <= Vs4) {
      maxSpacing = Math.min(d / 2, 24); // inches
    } else {
      maxSpacing = Math.min(d / 4, 12); // inches
    }
    
    // Seismic requirements per ACI 318-19 Section 18.6.4
    if (seismicCategory >= SeismicCategory.SDC_D) {
      if (memberType === MemberType.BEAM) {
        // Within 2h from face of support
        maxSpacing = Math.min(maxSpacing, d / 4, 6);
      } else if (memberType === MemberType.COLUMN) {
        maxSpacing = Math.min(maxSpacing, 6);
      }
    }
    
    // Minimum practical spacing
    const minSpacing = 3; // inches
    
    // Governing spacing
    const governingSpacing = Math.max(minSpacing, Math.min(requiredSpacing, maxSpacing));
    
    // Calculate provided capacity
    const VsProvided = (Av * fyt * d) / (governingSpacing * 1000);
    const AvRequired = VsRequired > 0 ? (VsRequired * 1000 * governingSpacing) / (fyt * d) : 0;
    
    return {
      requiredSpacing,
      maxSpacing,
      minSpacing,
      governingSpacing,
      AvRequired,
      AvProvided: Av,
      utilizationRatio: VsRequired > 0 ? VsRequired / VsProvided : 0
    };
  }

  /**
   * Calculate minimum shear reinforcement per ACI 318-19 Section 9.6.3.3
   */
  calculateMinimumReinforcement(
    fc: number,      // f'c in psi
    fyt: number,     // stirrup yield strength in psi
    bw: number,      // web width in inches
    s: number        // stirrup spacing in inches
  ): number {
    const sqrtFc = Math.sqrt(fc);
    const AvMin1 = 0.75 * sqrtFc * bw * s / fyt;
    const AvMin2 = 50 * bw * s / fyt;
    return Math.max(AvMin1, AvMin2); // in²
  }

  /**
   * Torsion design per ACI 318-19 Section 22.7
   */
  calculateTorsion(
    Tu: number,      // factored torsion in kip-ft
    fc: number,      // f'c in psi
    fyt: number,     // stirrup yield strength in psi
    fy: number,      // longitudinal bar yield strength in psi
    Acp: number,     // area enclosed by outer perimeter in in²
    pcp: number,     // outer perimeter in inches
    Aoh: number,     // area enclosed by centerline of stirrups in in²
    ph: number,      // perimeter of Aoh in inches
    Vu: number = 0   // concurrent factored shear in kips (for interaction)
  ): TorsionDesignResult {
    const sqrtFc = Math.sqrt(fc);
    
    // Cracking torsion per ACI 318-19 Eq. 22.7.5.1
    const Tcr = 4 * this.lambda * sqrtFc * (Acp * Acp / pcp) / 12000; // kip-ft
    
    // Check if torsion is significant
    const isTorsionSignificant = Tu > this.phi_torsion * Tcr / 4;
    
    // Torsional strength
    // At/s = Tu / (phi * 2 * Ao * fyt * cot(theta))
    // Assuming theta = 45 degrees (cot = 1)
    const Ao = 0.85 * Aoh;
    const theta = Math.PI / 4; // 45 degrees
    const cotTheta = 1 / Math.tan(theta);
    
    // Required transverse reinforcement (At/s)
    const AtPerS = (Tu * 12000) / (this.phi_torsion * 2 * Ao * fyt * cotTheta); // in²/in
    
    // Longitudinal reinforcement per ACI 318-19 Eq. 22.7.6.1
    const Al = (AtPerS * ph * fyt / fy) * cotTheta * cotTheta; // in²
    
    // Nominal torsion capacity
    const Tn = Tu / this.phi_torsion;
    
    return {
      Tu,
      Tcr,
      Tn,
      At: AtPerS * 12, // in²/ft
      Al,
      isTorsionSignificant
    };
  }
}

// ============================================================================
// Eurocode 2 Calculations (EN 1992-1-1)
// ============================================================================

class EC2Calculator {
  private readonly gamma_c = 1.5;  // Partial factor for concrete
  private readonly gamma_s = 1.15; // Partial factor for steel

  /**
   * Calculate concrete shear capacity per EC2 Section 6.2
   */
  calculateVRdc(
    fck: number,     // characteristic concrete strength in MPa
    bw: number,      // web width in mm
    d: number,       // effective depth in mm
    Asl: number,     // longitudinal reinforcement area in mm²
    NEd: number = 0  // axial force in kN (+ compression)
  ): ShearCapacityResult {
    // Design concrete strength
    const fcd = fck / this.gamma_c;
    
    // Reinforcement ratio
    const rhoL = Math.min(Asl / (bw * d), 0.02);
    
    // Size effect factor
    const k = Math.min(1 + Math.sqrt(200 / d), 2.0);
    
    // Stress from axial load
    const Ac = bw * d * 1.2; // Approximate
    const sigmaCP = Math.min(NEd * 1000 / Ac, 0.2 * fcd);
    
    // Minimum shear strength
    const vMin = 0.035 * Math.pow(k, 1.5) * Math.sqrt(fck);
    
    // Design shear resistance
    const CRdc = 0.18 / this.gamma_c;
    const k1 = 0.15;
    
    const VRdc1 = (CRdc * k * Math.pow(100 * rhoL * fck, 1/3) + k1 * sigmaCP) * bw * d / 1000;
    const VRdc2 = (vMin + k1 * sigmaCP) * bw * d / 1000;
    
    const VRdc = Math.max(VRdc1, VRdc2); // kN
    
    // Maximum shear resistance (strut crushing)
    const nu = 0.6 * (1 - fck / 250);
    const VRdMax = 0.5 * nu * fcd * bw * d / 1000; // kN
    
    // Simplified maximum steel shear
    const VRdsMax = VRdMax - VRdc;
    
    return {
      Vc: VRdc,
      VsMax: VRdsMax,
      VuMax: VRdMax,
      phi: 1.0, // Partial factors already applied
      isShearReinfRequired: false, // Determined by comparing with VEd
      minimumReinfRequired: true
    };
  }

  /**
   * Calculate stirrup spacing per EC2 Variable Strut Inclination Method
   */
  calculateStirrupSpacing(
    VEd: number,     // design shear force in kN
    VRdc: number,    // concrete shear resistance in kN
    fck: number,     // characteristic concrete strength in MPa
    fywk: number,    // characteristic yield strength of stirrups in MPa
    bw: number,      // web width in mm
    d: number,       // effective depth in mm
    z: number,       // lever arm (typically 0.9d) in mm
    Asw: number,     // stirrup area (total legs) in mm²
    memberType: MemberType = MemberType.BEAM
  ): StirrupSpacingResult {
    const fywd = fywk / this.gamma_s;
    
    // Determine strut angle (21.8° to 45°)
    // For simplicity, use cot(theta) = 2.5 for low shear, 1.0 for high shear
    const fcd = fck / this.gamma_c;
    const nu = 0.6 * (1 - fck / 250);
    const VRdMax = 0.5 * nu * fcd * bw * z / 1000;
    
    const ratio = VEd / VRdMax;
    let cotTheta: number;
    if (ratio <= 0.25) {
      cotTheta = 2.5;
    } else if (ratio >= 1.0) {
      cotTheta = 1.0;
    } else {
      cotTheta = 2.5 - 1.5 * (ratio - 0.25) / 0.75;
    }
    
    // Required Asw/s per EC2 Eq. 6.8
    const VsRequired = Math.max(0, VEd - VRdc);
    let requiredSpacing: number;
    
    if (VsRequired > 0) {
      // Asw/s = VRds / (z * fywd * cot(theta))
      const AswPerS = VsRequired * 1000 / (z * fywd * cotTheta); // mm²/mm
      requiredSpacing = Asw / AswPerS; // mm
    } else {
      requiredSpacing = 9999;
    }
    
    // Maximum spacing per EC2 Section 9.2.2
    const maxSpacing = Math.min(0.75 * d, 400); // mm
    
    // Minimum spacing (practical)
    const minSpacing = 75; // mm
    
    // Governing spacing
    const governingSpacing = Math.max(minSpacing, Math.min(requiredSpacing, maxSpacing));
    
    // Provided capacity
    const VsProvided = (Asw * z * fywd * cotTheta) / (governingSpacing * 1000);
    const AvRequired = VsRequired > 0 ? (VsRequired * 1000 * governingSpacing) / (z * fywd * cotTheta) : 0;
    
    return {
      requiredSpacing,
      maxSpacing,
      minSpacing,
      governingSpacing,
      AvRequired,
      AvProvided: Asw,
      utilizationRatio: VsRequired > 0 ? VsRequired / (VsProvided + VRdc) : 0
    };
  }

  /**
   * Calculate minimum shear reinforcement per EC2 Section 9.2.2
   */
  calculateMinimumReinforcement(
    fck: number,     // characteristic concrete strength in MPa
    fywk: number,    // characteristic yield strength of stirrups in MPa
    bw: number,      // web width in mm
    s: number        // stirrup spacing in mm
  ): number {
    // Minimum reinforcement ratio
    const rhoWmin = 0.08 * Math.sqrt(fck) / fywk;
    return rhoWmin * bw * s; // mm²
  }
}

// ============================================================================
// IS 456:2000 Calculations
// ============================================================================

class IS456Calculator {
  private readonly gamma_m = 1.5; // Partial safety factor for concrete

  /**
   * Calculate concrete shear capacity per IS 456 Clause 40.2
   */
  calculateVc(
    fck: number,     // characteristic concrete strength in MPa
    b: number,       // width in mm
    d: number,       // effective depth in mm
    Ast: number,     // longitudinal reinforcement area in mm²
    Pu: number = 0   // factored axial load in kN
  ): ShearCapacityResult {
    // Percentage of steel
    const pt = 100 * Ast / (b * d);
    const ptLimited = Math.min(pt, 3.0);
    
    // Basic design shear strength (Table 19 of IS 456)
    // Interpolated formula
    const tau_c = this.getDesignShearStrength(fck, ptLimited);
    
    // Modification for axial compression
    let delta = 1.0;
    if (Pu > 0) {
      const Ag = b * d * 1.2;
      delta = 1 + 3 * Pu * 1000 / (Ag * fck);
      delta = Math.min(delta, 1.5);
    }
    
    // Shear capacity
    const Vc = delta * tau_c * b * d / 1000; // kN
    
    // Maximum shear stress (Clause 40.2.3)
    const tau_cMax = this.getMaxShearStress(fck);
    const VcMax = tau_cMax * b * d / 1000; // kN
    
    return {
      Vc,
      VsMax: VcMax - Vc,
      VuMax: VcMax,
      phi: 1.0,
      isShearReinfRequired: false,
      minimumReinfRequired: true
    };
  }

  /**
   * Get design shear strength from IS 456 Table 19
   */
  private getDesignShearStrength(fck: number, pt: number): number {
    // Simplified formula based on Table 19
    const beta = Math.max(0.8 * fck / (6.89 * pt + fck), 1.0);
    const tau_c = 0.85 * Math.sqrt(0.8 * fck) * (Math.sqrt(1 + 5 * beta) - 1) / (6 * beta);
    return Math.min(tau_c, 0.62 * Math.sqrt(fck));
  }

  /**
   * Get maximum shear stress from IS 456 Table 20
   */
  private getMaxShearStress(fck: number): number {
    if (fck <= 20) return 2.8;
    if (fck <= 25) return 3.1;
    if (fck <= 30) return 3.5;
    if (fck <= 35) return 3.7;
    if (fck <= 40) return 4.0;
    return 4.0;
  }

  /**
   * Calculate stirrup spacing per IS 456
   */
  calculateStirrupSpacing(
    Vu: number,      // factored shear force in kN
    Vc: number,      // concrete shear capacity in kN
    fy: number,      // yield strength of stirrups in MPa
    b: number,       // width in mm
    d: number,       // effective depth in mm
    Asv: number      // total area of stirrup legs in mm²
  ): StirrupSpacingResult {
    // Required steel shear
    const Vs = Math.max(0, Vu - Vc);
    
    // Required spacing
    // Vs = 0.87 * fy * Asv * d / sv
    let requiredSpacing: number;
    if (Vs > 0) {
      requiredSpacing = 0.87 * fy * Asv * d / (Vs * 1000);
    } else {
      requiredSpacing = 9999;
    }
    
    // Maximum spacing per IS 456 Clause 26.5.1.5
    const maxSpacing = Math.min(0.75 * d, 300); // mm
    
    // Minimum spacing
    const minSpacing = 75; // mm
    
    // Governing spacing
    const governingSpacing = Math.max(minSpacing, Math.min(requiredSpacing, maxSpacing));
    
    // Provided capacity
    const VsProvided = 0.87 * fy * Asv * d / (governingSpacing * 1000);
    const AvRequired = Vs > 0 ? (Vs * 1000 * governingSpacing) / (0.87 * fy * d) : 0;
    
    return {
      requiredSpacing,
      maxSpacing,
      minSpacing,
      governingSpacing,
      AvRequired,
      AvProvided: Asv,
      utilizationRatio: Vs > 0 ? Vs / (VsProvided + Vc) : 0
    };
  }

  /**
   * Calculate minimum shear reinforcement per IS 456 Clause 26.5.1.6
   */
  calculateMinimumReinforcement(
    fy: number,      // yield strength of stirrups in MPa
    b: number,       // width in mm
    sv: number       // stirrup spacing in mm
  ): number {
    // Asv >= 0.4 * b * sv / (0.87 * fy)
    return 0.4 * b * sv / (0.87 * fy); // mm²
  }
}

// ============================================================================
// Main Stirrup Design Calculator
// ============================================================================

export class StirrupDesignCalculator {
  private aciCalc = new ACI318Calculator();
  private ec2Calc = new EC2Calculator();
  private is456Calc = new IS456Calculator();

  /**
   * Helper to normalize input properties for legacy code compatibility
   */
  private normalizeInput(input: ShearDesignInput): any {
    return {
      ...input,
      // Map new property names to legacy ones used in calculations
      fc: input.concrete.compressiveStrength,
      width: input.webWidth,
      Vu: input.factoredShear,
      Mu: 0, // Not in interface, default to 0
      Nu: input.factoredAxial || 0,
      stirrupRebar: input.stirrupBar,
      longitudinalRebar: input.longitudinalBar || input.stirrupBar,
      stirrupArea: input.stirrupBar.area * 2, // Assume 2-legged by default
      longitudinalRebarArea: (input.longitudinalBar?.area || 0) * 4,
      stirrupType: StirrupType.TWO_LEGGED, // Default
      clearCover: input.cover,
      concrete: {
        ...input.concrete,
        fc: input.concrete.compressiveStrength
      }
    };
  }

  /**
   * Design stirrups for given input parameters
   */
  design(input: ShearDesignInput): StirrupDesignResult {
    const normalizedInput = this.normalizeInput(input);
    
    switch (input.designCode) {
      case ConcreteDesignCode.ACI_318_19:
      case ConcreteDesignCode.ACI_318_14:
        return this.designACI(normalizedInput, input);
      case ConcreteDesignCode.EUROCODE_2:
        return this.designEC2(normalizedInput, input);
      case ConcreteDesignCode.IS_456_2000:
        return this.designIS456(normalizedInput, input);
      default:
        return this.designACI(normalizedInput, input); // Default to ACI
    }
  }

  /**
   * Design stirrups per ACI 318
   */
  private designACI(normalized: any, original: ShearDesignInput): StirrupDesignResult {
    // Convert to US units if needed
    const isMetric = this.isMetricInput(normalized);
    
    let fc: number, bw: number, d: number, Vu: number, Mu: number, fyt: number, fy: number;
    let stirrupArea: number;
    
    if (isMetric) {
      // Convert from metric to US customary
      fc = normalized.fc * 145.038; // MPa to psi
      bw = normalized.width / 25.4; // mm to inches
      d = normalized.effectiveDepth / 25.4;
      Vu = normalized.Vu * 0.2248; // kN to kips
      Mu = (normalized.Mu || 0) * 0.7376; // kN·m to kip·ft
      fyt = normalized.stirrupRebar.yieldStrength * 145.038;
      fy = normalized.longitudinalRebar.yieldStrength * 145.038;
      stirrupArea = normalized.stirrupArea / 645.16; // mm² to in²
    } else {
      fc = normalized.fc;
      bw = normalized.width;
      d = normalized.effectiveDepth;
      Vu = normalized.Vu;
      Mu = normalized.Mu || 0;
      fyt = normalized.stirrupRebar.yieldStrength;
      fy = normalized.longitudinalRebar.yieldStrength;
      stirrupArea = normalized.stirrupArea;
    }
    
    // Calculate concrete shear capacity
    const shearCapacity = this.aciCalc.calculateVc(
      fc, bw, d, Vu, Mu, normalized.Nu || 0
    );
    
    // Calculate stirrup spacing
    const spacingResult = this.aciCalc.calculateStirrupSpacing(
      Vu,
      shearCapacity.Vc,
      fc,
      fyt,
      bw,
      d,
      stirrupArea,
      original.memberType,
      original.seismicCategory
    );
    
    // Calculate minimum reinforcement
    const AvMin = this.aciCalc.calculateMinimumReinforcement(
      fc, fyt, bw, spacingResult.governingSpacing
    );
    
    // Select optimal bar size
    const selectedBar = this.selectOptimalBar(
      Math.max(spacingResult.AvRequired, AvMin),
      normalized.stirrupType,
      original.designCode,
      !isMetric
    );
    
    // Convert results back to metric if needed
    let finalSpacing: number, VcResult: number, VsResult: number, VnResult: number;
    
    if (isMetric) {
      finalSpacing = spacingResult.governingSpacing * 25.4; // inches to mm
      VcResult = shearCapacity.Vc * 4.448; // kips to kN
      VsResult = (Vu / shearCapacity.phi - shearCapacity.Vc) * 4.448;
      VnResult = (shearCapacity.Vc + shearCapacity.VsMax) * 4.448;
    } else {
      finalSpacing = spacingResult.governingSpacing;
      VcResult = shearCapacity.Vc;
      VsResult = Vu / shearCapacity.phi - shearCapacity.Vc;
      VnResult = shearCapacity.Vc + shearCapacity.VsMax;
    }
    
    // Generate schedule
    const stirrupSchedule = this.generateSchedule(
      normalized.stirrupType,
      selectedBar.size,
      Math.ceil(finalSpacing),
      normalized.width,
      normalized.effectiveDepth,
      normalized.clearCover || 40
    );
    
    return this.createResult(original, {
      Vc: VcResult,
      Vs: Math.max(0, VsResult),
      Vn: VnResult,
      phi: shearCapacity.phi,
      requiredSpacing: isMetric ? spacingResult.requiredSpacing * 25.4 : spacingResult.requiredSpacing,
      maxSpacing: isMetric ? spacingResult.maxSpacing * 25.4 : spacingResult.maxSpacing,
      providedSpacing: Math.ceil(finalSpacing),
      selectedBarSize: selectedBar.size,
      numberOfLegs: this.getNumberOfLegs(normalized.stirrupType),
      Av: selectedBar.area * this.getNumberOfLegs(normalized.stirrupType),
      AvMin: isMetric ? AvMin * 645.16 : AvMin,
      utilizationRatio: spacingResult.utilizationRatio,
      isAdequate: spacingResult.utilizationRatio <= 1.0 && normalized.Vu <= shearCapacity.VuMax,
      warnings: this.generateWarnings(shearCapacity, spacingResult, normalized),
      stirrupSchedule
    });
  }

  /**
   * Design stirrups per Eurocode 2
   */
  private designEC2(normalized: any, original: ShearDesignInput): StirrupDesignResult {
    const fck = normalized.fc; // MPa
    const bw = normalized.width; // mm
    const d = normalized.effectiveDepth; // mm
    const z = 0.9 * d; // lever arm
    const VEd = normalized.Vu; // kN
    const fywk = normalized.stirrupRebar.yieldStrength; // MPa
    const Asw = normalized.stirrupArea; // mm²
    
    // Estimate longitudinal reinforcement area
    const Asl = normalized.longitudinalRebarArea || 0.015 * bw * d; // Assume 1.5% if not provided
    
    // Calculate concrete shear capacity
    const shearCapacity = this.ec2Calc.calculateVRdc(
      fck, bw, d, Asl, normalized.Nu || 0
    );
    
    // Calculate stirrup spacing
    const spacingResult = this.ec2Calc.calculateStirrupSpacing(
      VEd,
      shearCapacity.Vc,
      fck,
      fywk,
      bw,
      d,
      z,
      Asw,
      original.memberType
    );
    
    // Calculate minimum reinforcement
    const AvMin = this.ec2Calc.calculateMinimumReinforcement(
      fck, fywk, bw, spacingResult.governingSpacing
    );
    
    // Select optimal bar size
    const selectedBar = this.selectOptimalBar(
      Math.max(spacingResult.AvRequired, AvMin),
      normalized.stirrupType,
      original.designCode,
      false
    );
    
    // Generate schedule
    const stirrupSchedule = this.generateSchedule(
      normalized.stirrupType,
      selectedBar.size,
      Math.ceil(spacingResult.governingSpacing),
      normalized.width,
      normalized.effectiveDepth,
      normalized.clearCover || 40
    );
    
    return this.createResult(original, {
      Vc: shearCapacity.Vc,
      Vs: Math.max(0, VEd - shearCapacity.Vc),
      Vn: shearCapacity.VuMax,
      phi: 1.0,
      requiredSpacing: spacingResult.requiredSpacing,
      maxSpacing: spacingResult.maxSpacing,
      providedSpacing: Math.ceil(spacingResult.governingSpacing),
      selectedBarSize: selectedBar.size,
      numberOfLegs: this.getNumberOfLegs(normalized.stirrupType),
      Av: selectedBar.area * this.getNumberOfLegs(normalized.stirrupType),
      AvMin,
      utilizationRatio: spacingResult.utilizationRatio,
      isAdequate: spacingResult.utilizationRatio <= 1.0 && VEd <= shearCapacity.VuMax,
      warnings: this.generateWarnings(shearCapacity, spacingResult, normalized),
      stirrupSchedule
    });
  }

  /**
   * Design stirrups per IS 456:2000
   */
  private designIS456(normalized: any, original: ShearDesignInput): StirrupDesignResult {
    const fck = normalized.fc; // MPa
    const b = normalized.width; // mm
    const d = normalized.effectiveDepth; // mm
    const Vu = normalized.Vu; // kN
    const fy = normalized.stirrupRebar.yieldStrength; // MPa
    const Asv = normalized.stirrupArea; // mm²
    
    // Estimate longitudinal reinforcement
    const Ast = normalized.longitudinalRebarArea || 0.015 * b * d;
    
    // Calculate concrete shear capacity
    const shearCapacity = this.is456Calc.calculateVc(
      fck, b, d, Ast, normalized.Nu || 0
    );
    
    // Calculate stirrup spacing
    const spacingResult = this.is456Calc.calculateStirrupSpacing(
      Vu,
      shearCapacity.Vc,
      fy,
      b,
      d,
      Asv
    );
    
    // Calculate minimum reinforcement
    const AvMin = this.is456Calc.calculateMinimumReinforcement(
      fy, b, spacingResult.governingSpacing
    );
    
    // Select optimal bar size
    const selectedBar = this.selectOptimalBar(
      Math.max(spacingResult.AvRequired, AvMin),
      normalized.stirrupType,
      original.designCode,
      false
    );
    
    // Generate schedule
    const stirrupSchedule = this.generateSchedule(
      normalized.stirrupType,
      selectedBar.size,
      Math.ceil(spacingResult.governingSpacing),
      normalized.width,
      normalized.effectiveDepth,
      normalized.clearCover || 40
    );
    
    return this.createResult(original, {
      Vc: shearCapacity.Vc,
      Vs: Math.max(0, Vu - shearCapacity.Vc),
      Vn: shearCapacity.VuMax,
      phi: 1.0,
      requiredSpacing: spacingResult.requiredSpacing,
      maxSpacing: spacingResult.maxSpacing,
      providedSpacing: Math.ceil(spacingResult.governingSpacing),
      selectedBarSize: selectedBar.size,
      numberOfLegs: this.getNumberOfLegs(normalized.stirrupType),
      Av: selectedBar.area * this.getNumberOfLegs(normalized.stirrupType),
      AvMin,
      utilizationRatio: spacingResult.utilizationRatio,
      isAdequate: spacingResult.utilizationRatio <= 1.0 && Vu <= shearCapacity.VuMax,
      warnings: this.generateWarnings(shearCapacity, spacingResult, normalized),
      stirrupSchedule
    });
  }

  // ============================================================================
  // Helper Methods
  // ============================================================================

  private isMetricInput(normalized: any): boolean {
    // If width is > 50, assume metric (mm), otherwise US customary (inches)
    return normalized.width > 50;
  }

  /**
   * Create a standardized result that matches StirrupDesignResult interface
   */
  private createResult(original: ShearDesignInput, data: any): StirrupDesignResult {
    return {
      reinforcementRequired: data.Vs > 0,
      concreteCapacity: data.Vc,
      requiredSteelCapacity: data.Vs,
      maxSteelCapacity: data.Vn - data.Vc,
      totalCapacity: data.Vn * data.phi,
      phiFactor: data.phi,
      stirrupConfig: {
        type: StirrupType.TWO_LEGGED,
        barSize: data.selectedBarSize,
        legs: data.numberOfLegs,
        spacing: data.providedSpacing,
        maxSpacing: data.maxSpacing,
        minSpacing: 75, // Default minimum
      },
      requiredAvs: data.AvMin / data.providedSpacing,
      providedAvs: data.Av / data.providedSpacing,
      regions: [{
        startLocation: 0,
        endLocation: original.totalDepth * 2, // 2d from support
        spacing: data.providedSpacing,
        barSize: data.selectedBarSize,
        legs: data.numberOfLegs,
        type: 'CRITICAL',
        reasoning: 'Critical shear zone near support'
      }],
      checks: [
        {
          name: 'Shear Capacity',
          required: original.factoredShear,
          provided: data.Vn * data.phi,
          ratio: original.factoredShear / (data.Vn * data.phi),
          passed: data.isAdequate,
          reference: 'Shear design check'
        }
      ],
      isAdequate: data.isAdequate,
      utilization: data.utilizationRatio,
      warnings: data.warnings || [],
      steps: []
    };
  }

  private getNumberOfLegs(stirrupType: StirrupType): number {
    switch (stirrupType) {
      case StirrupType.TWO_LEGGED: return 2;
      case StirrupType.FOUR_LEGGED: return 4;
      case StirrupType.SIX_LEGGED: return 6;
      case StirrupType.SPIRAL: return 2;
      case StirrupType.HELICAL: return 2;
      default: return 2;
    }
  }

  private selectOptimalBar(
    requiredArea: number,
    stirrupType: StirrupType,
    designCode: ConcreteDesignCode,
    useUSBars: boolean
  ): { size: string; area: number } {
    const numLegs = this.getNumberOfLegs(stirrupType);
    const areaPerLeg = requiredArea / numLegs;
    
    if (useUSBars) {
      const barSizes: { size: USBarSize; area: number }[] = [
        { size: USBarSize.NO_3, area: 0.11 },
        { size: USBarSize.NO_4, area: 0.20 },
        { size: USBarSize.NO_5, area: 0.31 },
        { size: USBarSize.NO_6, area: 0.44 },
      ];
      
      for (const bar of barSizes) {
        if (bar.area >= areaPerLeg) {
          return { size: bar.size, area: bar.area };
        }
      }
      return { size: USBarSize.NO_6, area: 0.44 };
    } else {
      const barSizes: { size: MetricBarSize; area: number }[] = [
        { size: MetricBarSize.D8, area: 50.3 },
        { size: MetricBarSize.D10, area: 78.5 },
        { size: MetricBarSize.D12, area: 113.1 },
        { size: MetricBarSize.D16, area: 201.1 },
      ];
      
      for (const bar of barSizes) {
        if (bar.area >= areaPerLeg) {
          return { size: bar.size, area: bar.area };
        }
      }
      return { size: MetricBarSize.D16, area: 201.1 };
    }
  }

  private generateWarnings(
    shearCapacity: ShearCapacityResult,
    spacingResult: StirrupSpacingResult,
    normalized: any
  ): string[] {
    const warnings: string[] = [];
    
    if (spacingResult.utilizationRatio > 1.0) {
      warnings.push('⚠️ Stirrup capacity is insufficient. Consider reducing spacing or increasing bar size.');
    }
    
    if (spacingResult.requiredSpacing < spacingResult.minSpacing) {
      warnings.push('⚠️ Required spacing is less than minimum practical spacing. Consider increasing member size or concrete strength.');
    }
    
    if (normalized.Vu > shearCapacity.VuMax * shearCapacity.phi) {
      warnings.push('❌ Shear force exceeds maximum capacity. Section must be redesigned.');
    }
    
    if (spacingResult.governingSpacing < 75 && normalized.width > 50) {
      warnings.push('⚠️ Very tight stirrup spacing. Check constructability.');
    }
    
    return warnings;
  }

  private generateSchedule(
    stirrupType: StirrupType,
    barSize: string,
    spacing: number,
    width: number,
    depth: number,
    cover: number
  ): {
    barMark: string;
    quantity: number;
    shape: string;
    dimensions: { A: number; B: number; C?: number };
    bendingSchedule: string;
  } {
    const A = width - 2 * cover;
    const B = depth - 2 * cover;
    const hookLength = 10 * (parseInt(barSize.replace(/\D/g, '')) || 8); // 10 * bar diameter
    
    let shape: string;
    let dimensions: { A: number; B: number; C?: number };
    
    switch (stirrupType) {
      case StirrupType.TWO_LEG:
        shape = 'Closed rectangular';
        dimensions = { A, B };
        break;
      case StirrupType.FOUR_LEG:
        shape = 'Closed rectangular with inner tie';
        dimensions = { A, B, C: A / 3 };
        break;
      case StirrupType.SIX_LEG:
        shape = 'Closed rectangular with 2 inner ties';
        dimensions = { A, B, C: A / 4 };
        break;
      default:
        shape = 'Closed rectangular';
        dimensions = { A, B };
    }
    
    const totalLength = 2 * (A + B) + 2 * hookLength + 24 * 8; // Assume 8mm for hook development
    
    return {
      barMark: `S1-${barSize}`,
      quantity: -1, // To be calculated based on member length
      shape,
      dimensions,
      bendingSchedule: `Cut length: ${Math.ceil(totalLength)}mm, Hooks: 135° seismic hooks`
    };
  }
}

// Export singleton instance for convenience
export const stirrupCalculator = new StirrupDesignCalculator();
