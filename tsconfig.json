{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "files": [],
  "references": [
    { "path": "./apps/backend/node/tsconfig.json" },
    { "path": "./apps/frontend/tsconfig.json" }
  ],
  "exclude": ["node_modules", "dist", "build", ".turbo", "apps", "packages", "deploy-pkg", "scripts", "docs"]
}
