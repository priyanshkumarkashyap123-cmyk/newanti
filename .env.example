# AI Architect - Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# API KEYS
# ============================================

# Google Gemini API Key (Required for AI features)
GOOGLE_API_KEY=your_gemini_api_key_here

# ============================================
# DATABASE
# ============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiarchitect

# ============================================
# SERVICES
# ============================================

# Frontend URLs
VITE_API_URL=http://localhost:3001
VITE_PYTHON_API_URL=http://localhost:8000
VITE_RUST_API_URL=http://localhost:3002
VITE_WS_URL=ws://localhost:8000/ws

# ============================================
# SECURITY
# ============================================

# JWT Secret for authentication (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# Session secret
SESSION_SECRET=your_session_secret_here

# Internal service-to-service secret (min 16 chars, generate with: openssl rand -base64 32)
INTERNAL_SERVICE_SECRET=your_internal_service_secret_here

# Comma-separated list of admin/master emails
MASTER_EMAILS=admin@example.com

# ============================================
# PAYMENTS (Razorpay)
# ============================================

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ============================================
# AUTH (Clerk)
# ============================================

CLERK_SECRET_KEY=your_clerk_secret_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# ============================================
# FEATURES
# ============================================

# Enable experimental features
ENABLE_PINN=true
ENABLE_COLLABORATION=true
ENABLE_VOICE=true

# Max request body size in MB (Python backend)
MAX_REQUEST_BODY_MB=10

# ============================================
# ENVIRONMENT
# ============================================

NODE_ENV=development
ENVIRONMENT=development
