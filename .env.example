# BeamLab Ultimate - Environment Configuration
# Copy this file to .env and fill in the values
# For production deployment, set these via GitHub Secrets or Azure App Settings

# ============================================
# API KEYS
# ============================================

# Google Gemini API Key (Required for AI features)
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Optional — fallback for AI)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# DATABASE
# ============================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/beamlab

# ============================================
# SERVICES
# ============================================

# Frontend URL
FRONTEND_URL=http://localhost:5173

# API URLs for frontend (VITE_ prefix = exposed to browser)
VITE_API_URL=http://localhost:3001
VITE_PYTHON_API_URL=http://localhost:8000
VITE_RUST_API_URL=http://localhost:8080
VITE_WEBSOCKET_URL=ws://localhost:8000/ws
ANALYSIS_MAX_IN_FLIGHT=5
ADVANCED_MAX_IN_FLIGHT=5
DESIGN_MAX_IN_FLIGHT=5

# Inter-service URLs (backend-to-backend)
PYTHON_API_URL=http://localhost:8000
RUST_API_URL=http://localhost:8080

# ============================================
# SECURITY
# ============================================

# JWT Secret for authentication (generate with: openssl rand -base64 64)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Session secret
SESSION_SECRET=your_session_secret_here

# Internal service-to-service secret (min 16 chars, generate with: openssl rand -base64 32)
INTERNAL_SERVICE_SECRET=your_internal_service_secret_here

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://beamlabultimate.tech,https://www.beamlabultimate.tech

# Comma-separated list of admin/master emails
MASTER_EMAILS=admin@example.com

# ============================================
# PAYMENTS (PhonePe / Razorpay)
# ============================================

# TEMPORARY BILLING BYPASS
# true  = unlock all users to enterprise/pro features (default while KYC is pending)
# false = enforce payment/subscription verification
TEMP_UNLOCK_ALL=true

PHONEPE_MERCHANT_ID=your_phonepe_merchant_id
PHONEPE_SALT_KEY=your_phonepe_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT

# Razorpay credentials (test keys start with rzp_test_, live keys with rzp_live_)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Frontend payment gateway controls
VITE_PAYMENT_GATEWAY=razorpay
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ============================================
# AUTH (Clerk — https://clerk.com)
# ============================================

# Server-side secret (NEVER expose to frontend)
CLERK_SECRET_KEY=your_clerk_secret_key
# Client-side publishable key (safe to expose)
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
USE_CLERK=true

# ============================================
# MONITORING
# ============================================

# Sentry error tracking DSN
SENTRY_DSN=
VITE_SENTRY_DSN=

# ============================================
# FEATURES
# ============================================

# Enable experimental features
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_COLLABORATION=false
VITE_ENABLE_WEBGPU=true

# Max request body size in MB (Python backend)
MAX_REQUEST_BODY_MB=10

# ============================================
# ENVIRONMENT
# ============================================

NODE_ENV=development
ENVIRONMENT=development
PORT=3001
