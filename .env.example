# ============================================
# BeamLab Ultimate - Environment Variables
# ============================================
# This file documents all required environment variables
# Set these in Azure App Service Configuration

# ============================================
# FRONTEND (apps/web) - Azure Static Web App
# ============================================
# IMPORTANT: For production, use pk_live_* keys from Clerk Dashboard
# Development keys (pk_test_*) will show a warning in production
VITE_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_CLERK_PRODUCTION_KEY
VITE_PYTHON_API_URL=https://beamlab-backend-python.azurewebsites.net
VITE_API_URL=https://beamlab-backend-node.azurewebsites.net

# ============================================
# NODE.JS API (apps/api) - Azure App Service
# ============================================
PORT=8080
NODE_ENV=production
USE_CLERK=true
# IMPORTANT: For production, use sk_live_* keys from Clerk Dashboard
CLERK_SECRET_KEY=sk_live_YOUR_CLERK_PRODUCTION_SECRET
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/beamlab
FRONTEND_URL=https://beamlabultimate.tech

# ============================================
# RAZORPAY PAYMENT GATEWAY (Required for Indian payments)
# ============================================
# Get these from Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET
# Webhook secret from Razorpay Dashboard > Webhooks
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
# Plan IDs from Razorpay Dashboard > Products > Subscriptions
RAZORPAY_PRO_MONTHLY_PLAN_ID=plan_YOUR_MONTHLY_PLAN_ID
RAZORPAY_PRO_YEARLY_PLAN_ID=plan_YOUR_YEARLY_PLAN_ID
RAZORPAY_ENTERPRISE_MONTHLY_PLAN_ID=plan_YOUR_ENTERPRISE_PLAN_ID

# ============================================
# PYTHON ENGINE (apps/backend-python) - Azure App Service
# ============================================
GEMINI_API_KEY=AIza_YOUR_GOOGLE_AI_KEY
USE_MOCK_AI=false
FRONTEND_URL=https://beamlabultimate.tech
ALLOWED_ORIGINS=https://beamlabultimate.tech,https://www.beamlabultimate.tech
