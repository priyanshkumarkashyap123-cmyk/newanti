# ===========================================================================
# Docker Compose Environment Variables
# Copy this to .env and fill in real values before running docker-compose up
# ===========================================================================

# REQUIRED — Docker will refuse to start without these
JWT_SECRET=generate-a-random-64-char-secret-here
JWT_REFRESH_SECRET=generate-another-random-64-char-secret-here
MONGO_PASSWORD=generate-a-strong-mongodb-password-here

# OPTIONAL — Defaults shown
MONGO_USERNAME=beamlab_admin
IMAGE_TAG=latest
