# BeamLab deployment environment template
# Copy to .env.deploy in deployment environments and fill with real values.
# Never commit .env.deploy or real secrets.

# =========================
# Core runtime
# =========================
NODE_ENV=production
PORT=3001

# =========================
# Database
# =========================
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# =========================
# Auth
# =========================
USE_CLERK=true
CLERK_SECRET_KEY=sk_live_xxx
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx
JWT_SECRET=replace_with_secure_jwt_secret
JWT_REFRESH_SECRET=replace_with_secure_jwt_refresh_secret
SESSION_SECRET=replace_with_secure_session_secret

# =========================
# Service security / CORS
# =========================
INTERNAL_SERVICE_SECRET=replace_with_min_16_char_secret
CORS_ALLOWED_ORIGINS=https://beamlabultimate.tech,https://www.beamlabultimate.tech
FRONTEND_URL=https://www.beamlabultimate.tech

# =========================
# AI / Monitoring
# =========================
GEMINI_API_KEY=replace_with_gemini_api_key
SENTRY_DSN=

# =========================
# Service URLs
# =========================
PYTHON_API_URL=https://beamlab-backend-python.azurewebsites.net
RUST_API_URL=https://beamlab-rust-api.azurewebsites.net
VITE_API_URL=https://beamlab-backend-node.azurewebsites.net
VITE_PYTHON_API_URL=https://beamlab-backend-python.azurewebsites.net
VITE_RUST_API_URL=https://beamlab-rust-api.azurewebsites.net

# =========================
# Payments - Razorpay
# =========================
# Use rzp_live_* in production
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret

# Frontend payment flags
VITE_PAYMENT_GATEWAY=razorpay
VITE_RAZORPAY_KEY_ID=rzp_live_xxx

# Optional fallback gateway
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=PRODUCTION

# Disable bypass in production
TEMP_UNLOCK_ALL=false

# =========================
# Optional deployment tokens (store in CI secrets; avoid app runtime when possible)
# =========================
AZURE_STATIC_WEB_APPS_API_TOKEN=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
