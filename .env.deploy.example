## Deployment environment file (example)
# Copy this to `.env.deploy` and fill in values locally. DO NOT commit `.env.deploy`.

# Azure service principal JSON (stringified) or leave empty to use publish profiles / Kudu creds.
AZURE_CREDENTIALS=

# Alternatively, publish profile XML content for the Node app (beamlab-backend-node)
AZURE_WEBAPP_PUBLISH_PROFILE_API=

# Kudu credentials (optional - used as fallback if publish profile missing)
AZURE_NODE_DEPLOY_USER=
AZURE_NODE_DEPLOY_PASS=

# Publish profile for Python app (optional)
AZURE_WEBAPP_PUBLISH_PROFILE_PYTHON=
AZURE_PY_DEPLOY_USER=
AZURE_PY_DEPLOY_PASS=

# ACR credentials for Rust image (optional)
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# Application secrets (do NOT share)
MONGODB_URI=
JWT_SECRET=
JWT_REFRESH_SECRET=

# Optional: GitHub admin token (required to toggle repo visibility)
# Provide as environment variable instead of storing here when possible.
GITHUB_ADMIN_TOKEN=
# Example .env.deploy (DO NOT COMMIT SECRETS)
# Fill this file locally with production values before running deploy scripts.

MONGODB_URL=
CLERK_SECRET_KEY=
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
GEMINI_API_KEY=

INTERNAL_SERVICE_SECRET=
SENTRY_DSN=

AZURE_STATIC_WEB_APPS_API_TOKEN=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=
PHONEPE_ENV=

VITE_PHONEPE_MERCHANT_ID=
VITE_RAZORPAY_KEY_ID=
VITE_PAYMENT_GATEWAY=both
VITE_TEMP_UNLOCK_ALL=false

# Frontend build-time overrides (Vite prefix required to inject into build)
VITE_API_URL=
VITE_PYTHON_API_URL=
VITE_RUST_API_URL=
VITE_WEBSOCKET_URL=
VITE_USE_CLERK=true
VITE_CLERK_PUBLISHABLE_KEY=

# Notes:
# - Keep this file out of source control. Use it only locally and for deploy scripts that
#   push secrets into secure stores (GitHub Actions secrets / Azure App Settings).
# - Do NOT include Azure publish profiles in this file. Store those separately in a
#   secure vault or password manager and rotate them if they were ever committed.
