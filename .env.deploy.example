# Example .env.deploy (DO NOT COMMIT SECRETS)
# Fill this file locally with production values before running deploy scripts.

MONGODB_URL=
CLERK_SECRET_KEY=
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
GEMINI_API_KEY=

INTERNAL_SERVICE_SECRET=
SENTRY_DSN=

AZURE_STATIC_WEB_APPS_API_TOKEN=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=
PHONEPE_ENV=

VITE_PHONEPE_MERCHANT_ID=
VITE_RAZORPAY_KEY_ID=
VITE_PAYMENT_GATEWAY=both
VITE_TEMP_UNLOCK_ALL=false

# Frontend build-time overrides (Vite prefix required to inject into build)
VITE_API_URL=
VITE_PYTHON_API_URL=
VITE_RUST_API_URL=
VITE_WEBSOCKET_URL=
VITE_USE_CLERK=true
VITE_CLERK_PUBLISHABLE_KEY=

# Notes:
# - Keep this file out of source control. Use it only locally and for deploy scripts that
#   push secrets into secure stores (GitHub Actions secrets / Azure App Settings).
# - Do NOT include Azure publish profiles in this file. Store those separately in a
#   secure vault or password manager and rotate them if they were ever committed.
