# ============================================
# BeamLab Ultimate - Local Development
# ============================================
# Domain: https://beamlabultimate.tech
# Local dev: app.beamlabultimate.local

# ============================================
# FRONTEND (apps/frontend)
# ============================================
VITE_API_URL=http://api.beamlabultimate.local:3001
VITE_PYTHON_API_URL=http://api.beamlabultimate.local:8000
VITE_WEBSOCKET_URL=ws://api.beamlabultimate.local:3001
VITE_APP_NAME=BeamLab Ultimate
VITE_FRONTEND_URL=http://app.beamlabultimate.local:5173

# Google Gemini AI (get from https://makersuite.google.com/app/apikey)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Clerk Auth (get from https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_KEY

# ============================================
# NODE.JS API (apps/backend/node)
# ============================================
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
APP_NAME=BeamLab Ultimate API
DEBUG=true

# Frontend URLs (CORS)
FRONTEND_URL=http://app.beamlabultimate.local:5173
ALLOWED_ORIGINS=http://app.beamlabultimate.local:5173,https://beamlabultimate.tech,https://www.beamlabultimate.tech,http://localhost:5173,http://localhost:3000

# Database (Local MongoDB)
MONGODB_URI=mongodb://localhost:27017/beamlab-ultimate

# External APIs
PYTHON_API_URL=http://api.beamlabultimate.local:8000

# Auth
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_KEY

# Session
SESSION_SECRET=beamlab-ultimate-session-secret-dev

# ============================================
# PYTHON BACKEND (apps/backend/python)
# ============================================
HOST=0.0.0.0
PYTHON_PORT=8000
PYTHON_APP_NAME=BeamLab Ultimate Python API
PYTHON_DEBUG=True
PYTHON_RELOAD=True

# Frontend
PYTHON_FRONTEND_URL=http://app.beamlabultimate.local:5173
PYTHON_ALLOWED_ORIGINS=http://app.beamlabultimate.local:5173,https://beamlabultimate.tech,https://www.beamlabultimate.tech,http://localhost:5173,http://localhost:3000

# AI (Google Gemini)
GEMINI_API_KEY=AIzaXXX_YOUR_DEV_KEY_OR_MOCK
USE_MOCK_AI=true

# Database (PostgreSQL - optional)
DATABASE_URL=postgresql://user:password@localhost:5432/beamlab-dev
SQLALCHEMY_ECHO=true

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
LOG_LEVEL=debug
ENABLE_CORS=true
ENABLE_RATE_LIMITING=false
CACHE_ENABLED=false

# ============================================
# DOCKER/COMPOSE (If using containers)
# ============================================
COMPOSE_PROJECT_NAME=beamlab-ultimate
COMPOSE_FILE=docker-compose.yml

# MongoDB in Docker
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=beamlab-dev-pass

# Redis in Docker (optional)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=beamlab-dev-pass
