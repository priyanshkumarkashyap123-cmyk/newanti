# ============================================
# Bheemla Ultimate - Local Development
# ============================================
# Domain-based configuration (not localhost)
# Use: app.bheemla.local, api.bheemla.local

# ============================================
# FRONTEND (apps/web)
# ============================================
VITE_API_URL=http://api.bheemla.local:3001
VITE_PYTHON_API_URL=http://api.bheemla.local:3002
VITE_WEBSOCKET_URL=ws://api.bheemla.local:3001
VITE_APP_NAME=Bheemla Ultimate
VITE_FRONTEND_URL=http://app.bheemla.local:5173

# Clerk Auth (optional for testing)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_bheemla_dev

# ============================================
# NODE.JS API (apps/api)
# ============================================
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
APP_NAME=Bheemla Ultimate API
DEBUG=true

# Frontend URLs (CORS)
FRONTEND_URL=http://app.bheemla.local:5173
ALLOWED_ORIGINS=http://app.bheemla.local:5173,http://www.bheemla.local:5173,http://localhost:5173,http://localhost:3000

# Database (Local MongoDB)
MONGODB_URI=mongodb://localhost:27017/bheemla-ultimate

# External APIs
PYTHON_API_URL=http://api.bheemla.local:3002

# Auth
CLERK_SECRET_KEY=sk_test_bheemla_dev
CLERK_PUBLISHABLE_KEY=pk_test_bheemla_dev

# Session
SESSION_SECRET=bheemla-ultimate-session-secret-dev

# ============================================
# PYTHON BACKEND (apps/backend-python)
# ============================================
HOST=0.0.0.0
PYTHON_PORT=3002
PYTHON_APP_NAME=Bheemla Ultimate Python API
PYTHON_DEBUG=True
PYTHON_RELOAD=True

# Frontend
PYTHON_FRONTEND_URL=http://app.bheemla.local:5173
PYTHON_ALLOWED_ORIGINS=http://app.bheemla.local:5173,http://www.bheemla.local:5173,http://localhost:5173,http://localhost:3000

# AI (Google Gemini)
GEMINI_API_KEY=AIzaXXX_YOUR_DEV_KEY_OR_MOCK
USE_MOCK_AI=true

# Database (PostgreSQL - optional)
DATABASE_URL=postgresql://user:password@localhost:5432/bheemla-dev
SQLALCHEMY_ECHO=true

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
LOG_LEVEL=debug
ENABLE_CORS=true
ENABLE_RATE_LIMITING=false
CACHE_ENABLED=false

# ============================================
# DOCKER/COMPOSE (If using containers)
# ============================================
COMPOSE_PROJECT_NAME=bheemla-ultimate
COMPOSE_FILE=docker-compose.yml

# MongoDB in Docker
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=bheemla-dev-pass

# Redis in Docker (optional)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=bheemla-dev-pass
