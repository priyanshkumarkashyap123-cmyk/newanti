{
  "name": "@beamlab/api",
  "version": "2.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx src/index.ts",
    "dev:watch": "tsx watch --env-file=.env src/index.ts",
    "build": "node build.mjs",
    "build:tsc": "tsc --skipLibCheck --noEmit false",
    "start": "node dist/index.js",
    "lint": "eslint . --ext ts --max-warnings 100",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx src/migrations/runner.ts",
    "migrate:status": "tsx src/migrations/runner.ts --status",
    "migrate:rollback": "tsx src/migrations/runner.ts --down"
  },
  "dependencies": {
    "@clerk/express": "^1.7.58",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.37.0",
    "@sentry/profiling-node": "^10.37.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.10.0",
    "mongoose": "^9.0.2",
    "nodemailer": "^7.0.11",
    "openai": "^6.15.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "query-string": "^9.3.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.9.3",
    "@types/nodemailer": "^7.0.4",
    "@types/query-string": "^6.3.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^3.2.1"
  }
}
