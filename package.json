{
  "name": "beamlab-ultimate",
  "version": "1.1.0",
  "private": true,
  "description": "BeamLab Ultimate - Professional Structural Analysis Platform",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:run": "turbo run test:run",
    "test:e2e": "pnpm --filter @beamlab/web test:e2e",
    "test:e2e:ui": "pnpm --filter @beamlab/web test:e2e:ui",
    "analyze": "pnpm --filter @beamlab/web analyze",
    "check-budget": "npx tsx scripts/check-budget.ts",
    "storybook": "pnpm --filter @beamlab/web storybook",
    "build-storybook": "pnpm --filter @beamlab/web build-storybook",
    "prepare": "husky",
    "release": "semantic-release",
    "validate": "pnpm lint && pnpm type-check && pnpm test:run"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.7",
    "@commitlint/cli": "^18.6.0",
    "@commitlint/config-conventional": "^18.6.0",
    "@eslint/js": "^9.39.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "eslint": "^9.39.2",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "semantic-release": "^22.0.12",
    "turbo": "^2.7.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "jotai": "^2.18.0"
  }
}
