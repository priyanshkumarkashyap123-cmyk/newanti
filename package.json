{
  "name": "@beamlab/api",
  "version": "2.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "scripts": {
    "check:routes:versioning": "node scripts/check-versioned-routes.mjs",
    "check:launch:contracts": "bash -lc 'cd apps/api && pnpm vitest run src/__tests__/launchContractSnapshots.test.ts'",
    "check:launch:fitness": "pnpm run check:routes:versioning && pnpm run check:launch:contracts",
    "check:postdeploy:smoke": "./scripts/run-postdeploy-smoke.sh",
    "check:parity:smoke": "./scripts/run-parity-smoke.sh tests/solver-parity/fixtures",
    "audit:production": "bash scripts/production-readiness-audit.sh",
    "check:file-sizes": "node scripts/check-file-sizes.mjs",
    "check:rust:god-files": "python3 scripts/audit_rust_god_files.py --root apps/backend-rust/src --warn-lines 800 --fail-lines 1200",
    "check:rust:god-files:enforce": "python3 scripts/audit_rust_god_files.py --root apps/backend-rust/src --warn-lines 800 --fail-lines 1200 --fail-on-god",
    "dev": "node --env-file=.env --import tsx src/index.ts",
    "dev:watch": "tsx watch --env-file=.env src/index.ts",
    "build": "node apps/api/build.mjs",
    "build:tsc": "tsc --skipLibCheck --noEmit false",
    "start": "node dist/index.js",
    "lint": "eslint . --ext ts --max-warnings 100",
    "type-check": "tsc --noEmit",
    "type-check:workspace": "pnpm -r --if-present run type-check",
    "clean": "rm -rf dist",
    "test": "vitest --exclude=\"apps/web/e2e/**\" --exclude=\"**/playwright.config.*\"",
    "test:run": "vitest run --exclude=\"apps/web/e2e/**\" --exclude=\"**/playwright.config.*\"",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx src/migrations/runner.ts",
    "migrate:status": "tsx src/migrations/runner.ts --status",
    "migrate:rollback": "tsx src/migrations/runner.ts --down",
    "load:capacity:health": "k6 run tests/load/capacity-staged.js --env PROFILE=health --summary-export ./k6-summary.json",
    "load:capacity:w1": "k6 run tests/load/capacity-staged.js --env PROFILE=w1 --env ENABLE_ANALYSIS=true --env AUTH_TOKEN=${AUTH_TOKEN} --summary-export ./k6-summary.json",
    "load:capacity:w2": "k6 run tests/load/capacity-staged.js --env PROFILE=w2 --env ENABLE_ANALYSIS=true --env AUTH_TOKEN=${AUTH_TOKEN} --summary-export ./k6-summary.json",
    "load:capacity:w3": "k6 run tests/load/capacity-staged.js --env PROFILE=w3 --env ENABLE_ANALYSIS=true --env AUTH_TOKEN=${AUTH_TOKEN} --summary-export ./k6-summary.json",
    "load:capacity:w4": "k6 run tests/load/capacity-staged.js --env PROFILE=w4 --env ENABLE_ANALYSIS=true --env AUTH_TOKEN=${AUTH_TOKEN} --summary-export ./k6-summary.json",
    "load:phase8": "bash tests/load/run-phase8-capacity.sh",
    "load:summary": "node tests/load/capacity-summary.mjs ./k6-summary.json",
    "load:full": "npm run load:capacity:w2 && npm run load:summary"
  },
  "dependencies": {
    "@clerk/express": "^1.7.58",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.37.0",
    "@sentry/profiling-node": "^10.37.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.10.0",
    "mongoose": "^9.0.2",
    "nodemailer": "^7.0.11",
    "openai": "^6.15.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "query-string": "^9.3.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.9.3",
    "@types/nodemailer": "^7.0.4",
    "@types/query-string": "^6.3.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^3.2.1"
  },
  "pnpm": {
    "overrides": {
      "qs": "^6.14.2",
      "dompurify": "^3.3.2",
      "minimatch": "^9.0.7"
    }
  }
}
